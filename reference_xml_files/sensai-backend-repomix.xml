        JOIN users u ON uo.user_id = u.id 
        WHERE uo.org_id = ? AND uo.deleted_at IS NULL AND u.deleted_at IS NULL""",
        (org_id,),
        fetch_all=True,
    )

    return [
        {
            "id": org_user[0],
            "email": org_user[1],
            "role": org_user[2],
        }
        for org_user in org_users
    ]


