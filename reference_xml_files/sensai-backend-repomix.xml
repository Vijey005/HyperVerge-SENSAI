    WHERE ct.course_id = ? AND t.deleted_at IS NULL AND t.type = '{TaskType.LEARNING_MATERIAL}' AND t.status = '{TaskStatus.PUBLISHED}'
    ORDER BY ct.ordering ASC
    """

    query_params = (course_id,)

